+    if (!authorized) {
+      await interaction.editReply({ content: '❌ That user is not authorized in the encrypted allow list.', ephemeral: true });
+      return;
+    }
+
+    const botMember = guild.members.me;
+    if (!botMember) {
+      await interaction.editReply({ content: '❌ Bot member data is unavailable.', ephemeral: true });
+      return;
+    }
+
